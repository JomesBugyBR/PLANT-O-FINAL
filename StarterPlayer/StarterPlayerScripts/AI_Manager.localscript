local Players = game:GetService("Players")\nlocal player = Players.LocalPlayer\nlocal camera = game.Workspace.CurrentCamera\nlocal replicatedStorage = game:GetService("ReplicatedStorage")\nlocal sound = Instance.new("Sound")\n\nsound.SoundId = "rbxassetid://YOUR_SOUND_ID" -- Replace with your jumpscare sound ID\nsound.Parent = game.Workspace\n\nlocal function jumpscare()\n    -- Camera shaking effect\n    local originalPosition = camera.CFrame.Position\n    for i = 1, 10 do\n        camera.CFrame = CFrame.new(originalPosition + Vector3.new(math.random(-1, 1), math.random(-1, 1), math.random(-1, 1)))\n        wait(0.05)\n    end\n    camera.CFrame = CFrame.new(originalPosition) -- Reset to original position\n\n    -- Play jumpscare sound\n    sound:Play()\n\n    -- Additional jumpscare effects can be added here\nend\n\n-- Trigger the jumpscare based on any condition you choose\nplayer.CharacterAdded:Connect(function()\n    wait(3) -- Wait for 3 seconds after the character spawns\n    jumpscare() -- Call the jumpscare function\nend)